#!/bin/bash
# Claude Code Stop + Notification hook: spoken announcements for supported
# macOS terminals. Port of a sibling Linux setup's claude-announce, with its
# foot-terminal bell plumbing replaced by per-terminal focus queries.
#
# Modes (first argument):
#   stop (default)  announce the task that just finished
#   notification    announce what Claude is waiting on (AskUserQuestion
#                   questions and tool permission prompts both arrive as
#                   notification_type=permission_prompt; the pending tool_use
#                   in the transcript tells them apart)
#
# Pipeline: where the host terminal supports it, check whether this session's
# tab/pane is the one being viewed and exit silently if so. Otherwise: read the
# hook JSON on stdin, pull the last real user prompt plus Claude's final reply
# out of the transcript (claude-announce-extract.py), compress them into one
# short spoken sentence with Apple's on-device foundation model
# (claude-announce-summarize, falling back to `claude -p --model haiku`),
# synthesize with Kokoro TTS (af_heart voice, same as the Linux setup), and play
# it with afplay. Focus is re-checked before playback.
#
# Meetings: when any process is capturing the microphone (Zoom, Google Meet,
# Teams, Webex, Slack huddles... - claude-announce-miccheck, CoreAudio), the
# voice is swapped for a silent macOS banner carrying the same summary. A
# missing/failing detector deliberately falls through to voice. Mic state is
# re-checked before playback too, in case a call started mid-generation.
#
# Unlike Linux, no terminal fork is needed: foot owned the focus logic there;
# here the hook queries each focus-capable terminal through AppleScript or its
# CLI and fails open toward speaking when exact focus is unavailable.
#
# Every stage fails toward something audible (Kokoro -> say -> plain ding) and
# the script always exits 0 so it can never block a session.
#
# Env knobs:
#   CLAUDE_ANNOUNCE_INNER=1  set on the claude -p fallback so the inner
#                            session's own Stop hook exits immediately
#   CLAUDE_ANNOUNCE_FORCE=1  skip the terminal gate and both focus checks
#                            (used by setup.sh --test)
#   CLAUDE_ANNOUNCE_DEBUG=1  trace decisions to <base>/debug.log; the flag file
#                            <base>/debug turns this on without an env var
#
# Runtime pieces (created by setup.sh):
#   ~/.local/share/claude-ai-notifs/venv                       kokoro-onnx venv
#   ~/.local/share/claude-ai-notifs/kokoro-v1.0.onnx
#   ~/.local/share/claude-ai-notifs/voices-v1.0.bin
#   ~/.local/share/claude-ai-notifs/bin/claude-announce-summarize
#   ~/.local/share/claude-ai-notifs/bin/claude-announce-miccheck
#   ~/.local/share/claude-ai-notifs/enabled-terminals            picked terminals
#
# Wired into ~/.claude/settings.json (hooks.Stop and hooks.Notification) by
# setup.sh, by absolute path.

# Runtime files can contain transcript-derived summaries. Keep newly created
# logs, locks, and audio private even when invoked from a shell with a loose
# default umask (notably SSH sessions).
umask 077

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BASE="$HOME/.local/share/claude-ai-notifs"
VENV_PY="$BASE/venv/bin/python"
SUMMARIZE="$BASE/bin/claude-announce-summarize"
MICCHECK="$BASE/bin/claude-announce-miccheck"
EXTRACT="$REPO/bin/claude-announce-extract.py"
FOCUS="$REPO/bin/claude-announce-focus.py"
TTS="$REPO/bin/claude-announce-tts.py"
DING="/System/Library/Sounds/Glass.aiff"
# Terminals the user enabled at install (one canonical key per line, written by
# setup.sh). Absent = installed before multi-terminal support; announce anywhere.
ENABLED_FILE="$BASE/enabled-terminals"
DEBUG_LOG="$BASE/debug.log"
MODE="${1:-stop}"

# Recursion guard: the claude -p fallback is itself a claude session whose
# Stop hook would run this script again.
[ -n "$CLAUDE_ANNOUNCE_INNER" ] && exit 0

input=$(cat 2>/dev/null)

# True when some process is capturing the microphone (exit 0 = BUSY). Missing
# or failing tool means not-in-meeting, failing toward the voice.
in_meeting() {
    [ -x "$MICCHECK" ] && "$MICCHECK" >/dev/null 2>&1
}

# Silent banner notification; argv avoids any quoting of the message.
banner() {
    osascript -e 'on run argv' \
              -e 'display notification (item 1 of argv) with title "Claude Code"' \
              -e 'end run' "$1" >/dev/null 2>&1
    exit 0
}

# Audible fallback when no summary could be produced; in a meeting it becomes
# a generic banner instead of a sound.
ding() {
    dbg "ding: falling back to Glass/banner (no spoken summary)"
    if in_meeting; then
        if [ "$MODE" = "notification" ]; then
            banner "Waiting for your input"
        else
            banner "Turn finished"
        fi
    fi
    audio_lock
    trap 'audio_unlock' EXIT
    with_timeout 15 afplay "$DING" >/dev/null 2>&1
    exit 0
}

# Homebrew coreutils `timeout` when present, otherwise a background watchdog
# (macOS has no native timeout binary).
with_timeout() {
    local secs="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$secs" "$@"
        return
    fi
    "$@" &
    local pid=$!
    ( sleep "$secs" && kill -TERM "$pid" 2>/dev/null ) &
    local watcher=$!
    wait "$pid" 2>/dev/null
    local rc=$?
    kill "$watcher" 2>/dev/null
    wait "$watcher" 2>/dev/null
    return "$rc"
}

# Serialize audio playback so two sessions finishing at once queue instead of
# talking over each other. macOS lockf(1) holds an exclusive lock on an
# inherited file descriptor (fd 9) for the length of playback: the kernel
# arbitrates, so there is no PID bookkeeping, no stale state, and no reclamation
# race - if a holder dies the fd closes and the lock releases automatically.
# The lock file lives under $BASE (user-owned; shared by all the user's sessions
# because $HOME is constant across login/SSH/GUI contexts) rather than
# world-writable /tmp. Waiters block up to AUDIO_LOCK_WAIT then play unlocked
# rather than drop the announcement; playback is with_timeout-bounded so a hold
# is only seconds. If lockf or $BASE is missing, serialization is skipped and
# announcements still play.
AUDIO_LOCK="$BASE/audio.lock"
AUDIO_LOCK_WAIT=180             # max seconds to wait for our turn before playing anyway

audio_lock() {
    [ -d "$BASE" ] || return 0
    command -v lockf >/dev/null 2>&1 || return 0
    exec 9>"$AUDIO_LOCK" 2>/dev/null || return 0
    lockf -s -t "$AUDIO_LOCK_WAIT" 9 2>/dev/null || exec 9>&-   # timed out: play unlocked
    return 0
}

# Invoked indirectly via `trap 'audio_unlock' EXIT`, so shellcheck flags it as
# unreachable/uninvoked (SC2317 on older versions, SC2329 on newer).
# shellcheck disable=SC2317,SC2329
audio_unlock() {
    # Close fd 9; the kernel releases the lock. Harmless if it was never opened.
    exec 9>&- 2>/dev/null || true
    return 0
}

# Optional decision trace for diagnosing why a session did or did not speak.
# Off unless CLAUDE_ANNOUNCE_DEBUG is set or the flag file $BASE/debug exists;
# then appends to $BASE/debug.log. Args are only cheap strings (no subprocesses)
# so leaving calls in place costs nothing when disabled.
dbg() {
    { [ -n "$CLAUDE_ANNOUNCE_DEBUG" ] || [ -e "$BASE/debug" ]; } || return 0
    [ -e "$DEBUG_LOG" ] && chmod 600 "$DEBUG_LOG" 2>/dev/null
    printf '%s [%s %s] %s\n' "$(date '+%H:%M:%S')" "$MODE" "$$" "$*" >> "$DEBUG_LOG" 2>/dev/null
}

# Climb the process tree to the ancestor that owns the session tty (hooks run
# without a controlling terminal; the claude process has one, ttysNNN).
pid=$$
tty=""
for _ in 1 2 3 4 5 6 7 8; do
    t=$(ps -o tty= -p "$pid" 2>/dev/null | tr -d ' ')
    case "$t" in
        ttys*) tty="$t"; break ;;
    esac
    pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
    { [ -z "$pid" ] || [ "$pid" = "0" ] || [ "$pid" = "1" ]; } && break
done

# Resolve a Python for JSON parsing (WezTerm/kitty focus checks below) and for
# transcript extraction later. Prefer the venv python (always present after
# setup); fall back to any python3.
PY="$VENV_PY"
[ -x "$PY" ] || PY="$(command -v python3)"

# Frontmost application's bundle id - the dispatch key for focus detection.
front_bundle_id() {
    lsappinfo info -only bundleid "$(lsappinfo front 2>/dev/null)" 2>/dev/null \
        | sed -n 's/.*"CFBundleIdentifier"="\([^"]*\)".*/\1/p'
}

# True when an AppleScript-returned tty path (/dev/ttysNNN) is this session's.
tty_is_mine() { [ -n "$1" ] && [ "${1##*/}" = "$tty" ]; }

# Per-terminal "is this session the visible/active one" checks. Each runs only
# when its terminal is already frontmost (see is_focused), so it only decides
# whether that terminal's active tab/pane/window is THIS session. Return 0 to
# suppress (focused), 1 to speak; on any uncertainty they return 1 so an
# announcement is never silently dropped.

focus_terminal_app() {
    tty_is_mine "$(osascript -e 'tell application "Terminal" to tty of selected tab of front window' 2>/dev/null)"
}

# iTerm2's AppleScript name is "iTerm" (not "iTerm2").
focus_iterm() {
    tty_is_mine "$(osascript -e 'tell application "iTerm" to tty of current session of current window' 2>/dev/null)"
}

# Ghostty exposes tty only on builds newer than v1.3.1; on older builds the
# query is empty and we fall through to speak (a non-regression).
focus_ghostty() {
    tty_is_mine "$(osascript -e 'tell application "Ghostty" to tty of focused terminal of selected tab of front window' 2>/dev/null)"
}

# WezTerm has no AppleScript; use its CLI. The GUI-focused pane comes from
# list-clients (focused_pane_id); map this session to its pane via $WEZTERM_PANE
# or by matching the tty against list's tty_name.
focus_wezterm() {
    local bin focused mine
    bin=$(command -v wezterm 2>/dev/null) || bin="/Applications/WezTerm.app/Contents/MacOS/wezterm"
    { [ -x "$bin" ] && [ -n "$PY" ]; } || return 1
    focused=$("$bin" cli list-clients --format json 2>/dev/null \
        | "$PY" "$FOCUS" wezterm-focused 2>/dev/null)
    [ -n "$focused" ] || return 1
    mine="$WEZTERM_PANE"
    [ -n "$mine" ] || mine=$("$bin" cli list --format json 2>/dev/null \
        | "$PY" "$FOCUS" wezterm-pane "$tty" 2>/dev/null)
    [ -n "$mine" ] && [ "$focused" = "$mine" ]
}

# kitty via remote control: `kitty @ ls` needs allow_remote_control enabled
# (else it returns nothing and we speak). Match the GUI-focused window id to
# this session's inherited KITTY_WINDOW_ID.
focus_kitty() {
    local bin ls
    bin=$(command -v kitty 2>/dev/null) || bin="/Applications/kitty.app/Contents/MacOS/kitty"
    { [ -x "$bin" ] && [ -n "$PY" ] && [ -n "$KITTY_WINDOW_ID" ]; } || return 1
    ls=$("$bin" @ ls 2>/dev/null)
    [ -n "$ls" ] || return 1
    printf '%s' "$ls" | "$PY" "$FOCUS" kitty-focused "$KITTY_WINDOW_ID" 2>/dev/null
}

# Suppress the announcement only when the user is looking at THIS session's
# tab/pane. Dispatch on the frontmost app; terminals with no per-session focus
# API (Alacritty; Ghostty <= v1.3.1; kitty without remote control) fall through
# to speak. Any failure (no tty, AppleScript denied) also speaks - announcements
# fail open rather than being silently dropped.
is_focused() {
    [ -n "$CLAUDE_ANNOUNCE_FORCE" ] && return 1
    [ -n "$tty" ] || return 1
    case "$(front_bundle_id)" in
        com.apple.Terminal)     focus_terminal_app ;;
        com.googlecode.iterm2)  focus_iterm ;;
        com.mitchellh.ghostty)  focus_ghostty ;;
        com.github.wez.wezterm) focus_wezterm ;;
        net.kovidgoyal.kitty)   focus_kitty ;;
        *)                      return 1 ;;
    esac
}

# Canonical key for the terminal hosting THIS session, from the env the hook
# inherits from the session shell. Empty if unrecognized. Keys match the
# enabled-terminals file and setup.sh.
host_terminal() {
    # Terminal-specific vars first: they are set by the actual host terminal and
    # beat TERM_PROGRAM, which can be inherited stale (e.g. kitty launched from a
    # Terminal.app shell keeps TERM_PROGRAM=Apple_Terminal; kitty sets only
    # KITTY_WINDOW_ID). Terminal.app has no distinctive var, so it relies on
    # TERM_PROGRAM last.
    [ -n "$KITTY_WINDOW_ID" ] && { echo kitty; return; }
    [ -n "$WEZTERM_PANE" ] && { echo wezterm; return; }
    { [ -n "$GHOSTTY_RESOURCES_DIR" ] || [ -n "$GHOSTTY_SURFACE_ID" ]; } && { echo ghostty; return; }
    { [ -n "$ALACRITTY_WINDOW_ID" ] || [ -n "$ALACRITTY_SOCKET" ]; } && { echo alacritty; return; }
    [ -n "$ITERM_SESSION_ID" ] && { echo iterm2; return; }
    case "$TERM_PROGRAM" in
        Apple_Terminal) echo terminal; return ;;
        iTerm.app)      echo iterm2;   return ;;
        WezTerm)        echo wezterm;  return ;;
        ghostty)        echo ghostty;  return ;;
    esac
    case "$TERM" in
        xterm-kitty)   echo kitty;   return ;;
        xterm-ghostty) echo ghostty; return ;;
    esac
    echo ""
}

# Gate: only announce for sessions whose host terminal was enabled at install.
# Missing file = pre-feature install, announce everywhere (backward compatible).
# An unrecognized host is treated as not-enabled (stay silent) so the tool only
# ever speaks where the user opted in. CLAUDE_ANNOUNCE_FORCE bypasses the gate.
terminal_enabled() {
    [ -n "$CLAUDE_ANNOUNCE_FORCE" ] && return 0
    [ -f "$ENABLED_FILE" ] || return 0
    local host; host=$(host_terminal)
    [ -n "$host" ] && grep -qxF "$host" "$ENABLED_FILE"
}

# Do nothing in terminals the user did not enable this in.
dbg "invoked: host='$(host_terminal)' tty='$tty'"
terminal_enabled || { dbg "exit: terminal not in enabled list"; exit 0; }

# Silent while the user is watching this tab, exactly like foot's
# command-focused=no on Linux.
is_focused && { dbg "exit: focused (user is looking at this session)"; exit 0; }
dbg "not focused -> will announce"

# Extract the announcement material from the transcript (PY resolved above).
[ -n "$PY" ] || ding
task=$(printf '%s' "$input" | "$PY" "$EXTRACT" "$MODE" 2>/dev/null)
[ -n "$task" ] || { dbg "ding: extract produced empty task"; ding; }
dbg "task: ${#task} chars"

if [ "$MODE" = "notification" ]; then
    instruction="Claude, the user's AI coding assistant, has paused and needs the user. In ONE sentence, at most 14 words, tell the user what Claude is asking or waiting for. Present tense, plain English, no quotes, no preamble, no emojis."
else
    instruction="Claude, the user's AI coding assistant, just finished a task. Summarize what happened in ONE sentence of at most 14 words, past tense, plain English, no quotes, no preamble, no emojis. Base it ONLY on what the assistant reply says was done or found; never infer an outcome from the user request. If the reply is missing or does not clearly state an outcome, say what Claude worked on without claiming it succeeded or is fixed. If the request was a question, announce what was answered or found, never a fabricated action."
fi

clean() {
    tr -d '"' | tr '\n' ' ' | sed 's/^ *//; s/ *$//' | head -c 300
}

# The on-device model follows the task best when the full instruction lives in
# the prompt with a trailer, not in the session instructions (tested: putting
# it in instructions makes the 3B-class model echo the reply verbatim).
prompt="$instruction

$task

One-sentence announcement:"

summary=""; via=""
if [ -x "$SUMMARIZE" ]; then
    summary=$(with_timeout 30 "$SUMMARIZE" \
        "You write one-line spoken announcements for a terminal notification system." \
        "$prompt" 2>/dev/null </dev/null | clean)
    [ -n "$summary" ] && via="on-device"
    dbg "on-device summarizer: ${#summary} chars"
fi
if [ -z "$summary" ] && command -v claude >/dev/null 2>&1; then
    summary=$(CLAUDE_ANNOUNCE_INNER=1 with_timeout 60 \
        claude -p --model haiku "$prompt" 2>/dev/null </dev/null | clean)
    [ -n "$summary" ] && via="claude -p"
    dbg "claude -p fallback: ${#summary} chars"
fi
[ -n "$summary" ] || { dbg "ding: no summary from on-device or claude -p"; ding; }
dbg "summary via $via: [$summary]"

# In a meeting, deliver the summary as a silent banner instead of speaking.
in_meeting && { dbg "delivering as banner (in meeting)"; banner "$summary"; }

# Kokoro synth; if the venv or models are missing, degrade to the native say
# voice rather than dropping the announcement.
make_wav_temp() {
    wav_dir=$(mktemp -d "${TMPDIR:-/tmp}/claude-announce.XXXXXX" 2>/dev/null) \
        || { wav_dir=""; wav=""; return 1; }
    wav="$wav_dir/announcement.wav"
}
cleanup_wav() { [ -z "$wav_dir" ] || rm -rf "$wav_dir"; }
wav_dir=""; wav=""
make_wav_temp || true
trap 'cleanup_wav' EXIT
if [ -n "$wav" ] && [ -x "$VENV_PY" ]; then
    with_timeout 45 "$VENV_PY" "$TTS" "$summary" "$wav" >/dev/null 2>&1
fi

# Generation took a few seconds: if the user switched to this tab meanwhile
# stay silent, and if a call started meanwhile use the banner.
is_focused && { cleanup_wav; exit 0; }
in_meeting && { cleanup_wav; banner "$summary"; }

# Serialize playback: wait our turn so concurrent announcements queue rather
# than overlap. Re-check focus/meeting once we hold the channel, since we may
# have waited behind another announcement and the state can change meanwhile.
audio_lock
trap 'audio_unlock; cleanup_wav' EXIT
is_focused && { cleanup_wav; exit 0; }
in_meeting && { cleanup_wav; banner "$summary"; }

if [ -s "$wav" ]; then
    dbg "playing kokoro wav via afplay"
    with_timeout 30 afplay "$wav" >/dev/null 2>&1
else
    dbg "no wav (kokoro unavailable/failed) -> native say"
    with_timeout 30 say "$summary" >/dev/null 2>&1
fi
cleanup_wav
exit 0
